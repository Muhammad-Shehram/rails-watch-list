<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>My Movie Lists</h1>
    <%= link_to "Create a list", new_list_path, class: "btn-cinema" %>
  </div>

  <div class="list-grid">
    <% @lists.each do |list| %>
      <%= link_to list_path(list), class: "list-card" do %>
        <h2><%= list.name %></h2>
        <small class="text-muted"><%= list.bookmarks.count %> movies</small>
      <% end %>
    <% end %>
  </div>
</div>
