<div class="container py-5">
  <div class="d-flex align-items-center justify-content-between mb-5">
    <h1 class="mb-0 font-weight-bold">My Movie Lists</h1>
    <%= link_to "Create a new list", new_list_path, class: "btn-cinema" %>
  </div>

  <div class="row">
    <% @lists.each do |list| %>
      <div class="col-12 col-sm-6 col-md-4 mb-4">
        <%# Wrapping the entire card in a link makes the whole area clickable %>
        <%= link_to list_path(list), class: "text-decoration-none" do %>
          <div class="card-list shadow-sm h-100 border rounded-lg overflow-hidden">

            <%# 🖼️ Image Logic %>
            <% if list.photo.attached? %>
              <%= cl_image_tag list.photo.key, height: 250, width: 400, crop: :fill, class: "card-img-top object-fit-cover" %>
            <% else %>
              <img src="https://images.unsplash.com/photo-1489599849927-2ee91cede3ba" class="card-img-top object-fit-cover" style="height: 250px;">
            <% end %>

            <div class="card-body bg-white text-center py-4">
              <h4 class="card-title mb-1 text-dark font-weight-bold"><%= list.name %></h4>
              <small class="text-muted"><%= pluralize(list.bookmarks.count, 'movie') %></small>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
