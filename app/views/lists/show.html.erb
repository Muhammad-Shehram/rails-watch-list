<%# 🎥 THE CINEMATIC BANNER %>
<%# We use cl_image_path for the URL inside the inline style to make the background dynamic %>
<div class="banner" style="background-image: linear-gradient(rgba(0,0,0,0.4),rgba(0,0,0,0.4)), url('<%= @list.photo.attached? ? cl_image_path(@list.photo.key) : "https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80" %>');">
  <h1><%= @list.name %></h1>
</div>

<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="font-weight-bold">Movies</h2>
    <%= link_to "Add a movie", new_list_bookmark_path(@list), class: "btn-cinema" %>
  </div>

  <div class="movie-grid">
    <% @list.bookmarks.each do |bookmark| %>
      <div class="movie-card shadow-sm">
        <%# Clean text-only remove link (No "X" icon) %>
        <%= link_to "remove", bookmark_path(bookmark),
                    data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                    class: "delete-link" %>

        <img src="<%= bookmark.movie.poster_url %>" alt="<%= bookmark.movie.title %>">

        <div class="movie-content">
          <div class="d-flex justify-content-between">
            <h5 class="font-weight-bold"><%= bookmark.movie.title %></h5>
            <small class="text-muted"><%= bookmark.movie.rating %> ⭐</small>
          </div>
          <p class="text-muted small"><%= bookmark.movie.overview %></p>

          <%# The Red-Border Comment Section %>
          <div class="comment-block mt-3">
            <p class="mb-0">"<%= bookmark.comment %>"</p>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-5 mb-5 text-center">
    <%= link_to lists_path, class: "btn-back-cinema" do %>
      <i class="fa-solid fa-arrow-left-long me-2"></i> Back to all lists
    <% end %>
  </div>
</div>
