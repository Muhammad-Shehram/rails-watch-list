<%# Using a placeholder image or a solid color for the banner %>
<div class="banner" style="background-image: linear-gradient(rgba(0,0,0,0.6),rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80');">
  <h1><%= @list.name %></h1>
</div>

<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-5">
    <h2>Movies</h2>
    <%= link_to "Add a movie", new_list_bookmark_path(@list), class: "btn-cinema" %>
  </div>

  <div class="movie-grid">
    <% @list.bookmarks.each do |bookmark| %>
      <div class="movie-card">
        <%= link_to "Remove", bookmark_path(bookmark), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "delete-link" %>
        <img src="<%= bookmark.movie.poster_url %>" alt="<%= bookmark.movie.title %>">
        <div class="movie-content">
          <h3><%= bookmark.movie.title %></h3>
          <div class="rating">⭐ <%= bookmark.movie.rating %></div>
          <p class="text-muted small"><%= bookmark.movie.overview %></p>
          <p class="comment">"<%= bookmark.comment %>"</p>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-5 text-center">
    <%= link_to "← Back to lists", lists_path, class: "text-muted" %>
  </div>
</div>
